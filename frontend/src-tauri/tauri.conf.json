{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TelecomApp",
  "version": "0.3.6",
  "identifier": "com.telecom.tracking",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Telecom Work Tracking",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://86.57.150.169:8000 http://localhost:8000 http://192.168.0.100:8000; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Telecom",
    "shortDescription": "Telecom Work Tracking Application",
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://server375375-creator.github.io/telecom-app-updates/{{target}}-{{arch}}.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZFNEM4ODQ5Mzg1RTJDRjIKUldUeUxGNDRTWWhNL2lBMjJBQVYvQ3lrYWRIYzhFc0RDd3Y2UXFyOEZZbzZXVmIzRWdHM2Q2MVIK"
    }
  }
}
